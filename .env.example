# ═══════════════════════════════════════════════════════════════
#              НАСТРОЙКИ TELEGRAM ALARM BOT
#  Скопируй этот файл в .env и заполни своими данными:
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# URL базы данных PostgreSQL
DATABASE_URL=postgresql+asyncpg://alarm_user:alarm_password@localhost:5432/alarm_db

# Telegram API credentials (получить на https://my.telegram.org)
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Имя файла сессии Pyrogram (без расширения .session)
TELEGRAM_SESSION_NAME=pyrogram_session

# Директория для хранения сессии (необязательно, по умолчанию — текущая папка)
# TELEGRAM_SESSION_DIR=/path/to/sessions
